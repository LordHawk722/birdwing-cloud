# 数据库配置
DB_HOST=rm-xxx.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bird_watcing

# JWT 密钥（生产环境请修改）
JWT_SECRET_KEY=bird-watching-secret-key-change-in-production

# 百度AI识别（可选，不配置则使用模拟数据）
BAIDU_APP_ID=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# 通义千问 AI 识别
QWEN_API_KEY=
QWEN_MODEL=qwen3.6-flash

# 阿里云 OSS（图片上传 — 不配置则存本地磁盘）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# AI 聊天（默认使用 DeepSeek，兼容所有 OpenAI 格式 API）
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
